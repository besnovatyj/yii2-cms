# @see https://www.atlassian.com/ru/git/tutorials/saving-changes/gitignore#git-ignore-patterns

# Секреты
auth.json
.npmrc
keys/

# Служебное
.ash_history
/vendor/

# Environment-specific files (generated by init script)
/yii
/backend/pub/index.php
/backend/pub/robots.txt
/frontend/pub/index.php
/frontend/pub/robots.txt

# phpDocumentor
/docs/api/
/.phpdoc/

# Артефакты и временные файлы
/var/db/*
/var/config/*
/static/zip/
/tmp/
node_modules/
.npm/
/themes/berdramashock/
/themes/optimaExtended/
/themes/starrain/
/frontend/pub/basic/
/frontend/pub/static_assets_bd/

# Dev-площадка пакетов (каждый пакет — отдельный репо)
/packages/
