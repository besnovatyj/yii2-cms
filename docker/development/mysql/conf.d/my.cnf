#
# Dev-конфиг MySQL 8.4 (Docker).
# Логами рулит Docker: error log официальный образ шлёт в stderr -> docker logs.
# НИКАКИХ файловых логов здесь (log_error/slow_query_log_file в файл не задаём).
#
[mysqld]

#
# Безопасность
#
secure-file-priv = NULL   # Полный запрет LOAD DATA INFILE / SELECT ... INTO OUTFILE
local-infile = 0          # Отключает LOAD DATA LOCAL INFILE (паритет с prod)
sql_mode = STRICT_TRANS_TABLES,ERROR_FOR_DIVISION_BY_ZERO,NO_ENGINE_SUBSTITUTION

#
# Кодировка (паритет поведения с prod; раньше задавалась в docker-compose command)
#
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

#
# Dev: бинлог не нужен — экономим IO и место на диске
#
skip-log-bin

#
# Отключение устаревших движков (как на prod)
#
disabled_storage_engines = "MyISAM,MEMORY"

#
# InnoDB под локальную разработку (скромно)
#
innodb_file_per_table = ON
innodb_buffer_pool_size = 128M
innodb_flush_log_at_trx_commit = 2   # Быстрее на запись, для dev безопасности достаточно

#
# Performance Schema выключена — экономия RAM (как на prod)
#
performance_schema = OFF

[mysqldump]
max_allowed_packet = 64M

[mysql]
max_allowed_packet = 64M
