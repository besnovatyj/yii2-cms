server {
   listen 80;
   charset utf-8;
   # This should match the `post_max_size` and/or `upload_max_filesize` settings
   # in your php.ini.
   client_max_body_size 1024M;
   sendfile off;
   server_tokens off; # отключить отображение номера версии в сообщениях об ошибках и заголовке ответа

   server_name ${MAIN_HOST} www.${MAIN_HOST};
   root /app/frontend/pub/;
   index index.php;

   # не загружать, если источник не совпадает (запретить загружать в Iframe)
   add_header X-Frame-Options "SAMEORIGIN";
   # запрещает браузерам "нюхать" (sniff) MIME-тип содержимого.
   add_header X-Content-Type-Options "nosniff";

   add_header Content-Security-Policy-Report-Only "
   default-src 'self';
   script-src 'self' 'unsafe-inline' https://www.google.com https://www.gstatic.com;
   style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;
   img-src 'self' ${FILES_HOST} data: https:;
   font-src 'self' data: https://fonts.gstatic.com;
   connect-src 'self' https://www.google.com;
   media-src 'self' ${FILES_HOST};
   object-src 'none';
   frame-src https://www.google.com ${MAIN_HOST};
   frame-ancestors 'self';
   base-uri 'self';
   form-action 'self';
   upgrade-insecure-requests;
   report-uri https://${MAIN_HOST}/csp-report
   ";

   access_log /var/log/nginx/access-${MAIN_HOST}.log;
   error_log /var/log/nginx/error-${MAIN_HOST}.log;

   location ~ /\.(ht|svn|git|env|json|lock|yml) {
       deny all;
   }

   location / {
       # Redirect everything that isn't a real file to index.php
       try_files $uri $uri/ /index.php$is_args$args; # Этот вариант хуже - "try_files $uri $uri/ /index.php?$query_string;" /// $is_args добавляет ? только если запрос содержит аргументы (например, ?key=value). Это предотвращает лишний символ ? в URL, если аргументов нет. /// $query_string — это полная строка запроса, включая ?. Использование $query_string может привести к двойному ? в некоторых случаях. /// Рекомендуется использовать $is_args$args, как в вашем шаблоне, для большей надёжности и чистоты URL.
   }

    # Определяет блок обработки запросов, соответствующих файлам с расширением .php. Модификатор ~ указывает на регистронезависимое регулярное выражение, а \.php$ означает, что обрабатываются запросы, заканчивающиеся на .php.
    location ~ \.php$ {
        # Защита от подмены path_info (Путь к файлу index.php?)
        fastcgi_split_path_info ^(.+\.php)(/.+)$;
        fastcgi_pass php-fpm:9000;
        fastcgi_index index.php;
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
        try_files $uri =404;
    }

}

