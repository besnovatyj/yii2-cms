<ruleset name="App coding standard">
    <arg value="p"/>
    <arg name="colors"/>
    <arg name="cache" value="var/cache/.phpcs.json"/>

    <rule ref="PSR12"/>
    <rule ref="Generic.Arrays.DisallowLongArraySyntax"/>
    <rule ref="Squiz.WhiteSpace.SuperfluousWhitespace">
        <properties>
            <property name="ignoreBlankLines" value="false"/>
        </properties>
    </rule>

<!-- @see https://github.com/PHPCSStandards/PHP_CodeSniffer/wiki -->

    <file>backend</file>
    <file>common</file>
    <file>console</file>
    <file>frontend</file>
    <file>modules</file>
</ruleset>
